# ============================================================
# Kiibare Environment Variables (Copy to .env and customize)
# ============================================================

# Django
DJANGO_SECRET_KEY=change-me-to-a-real-secret-key-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# PostgreSQL
POSTGRES_DB=kiibare_db
POSTGRES_USER=kiibare_user
POSTGRES_PASSWORD=kiibare_password
DB_HOST=db
DB_PORT=5432

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
